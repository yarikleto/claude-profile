#!/usr/bin/env bash
# claude-profile — Switch between Claude Code configuration profiles
# https://github.com/yarikleto/claude-profile
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ─── Load modules ──────────────────────────────────────────
source "$SCRIPT_DIR/lib/output.sh"
source "$SCRIPT_DIR/lib/config.sh"
source "$SCRIPT_DIR/lib/git.sh"
source "$SCRIPT_DIR/lib/state.sh"
source "$SCRIPT_DIR/lib/files.sh"
source "$SCRIPT_DIR/commands/profile.sh"
source "$SCRIPT_DIR/commands/info.sh"
source "$SCRIPT_DIR/commands/history.sh"
source "$SCRIPT_DIR/commands/ui.sh"

# ─── Dispatch ──────────────────────────────────────────────
cmd="${1:-help}"
shift 2>/dev/null || true

case "$cmd" in
  new)            cmd_new "$@" ;;
  fork)           cmd_fork "$@" ;;
  use|switch)     cmd_use "$@" ;;
  save)           cmd_save "$@" ;;
  deactivate|off) cmd_deactivate "$@" ;;
  list|ls)        cmd_list "$@" ;;
  current)        cmd_current "$@" ;;
  show|info)      cmd_show "$@" ;;
  edit)           cmd_edit "$@" ;;
  delete|rm)      cmd_delete "$@" ;;
  history|log)    cmd_history "$@" ;;
  diff)           cmd_diff "$@" ;;
  restore)        cmd_restore "$@" ;;
  prompt-init)    cmd_prompt_init "$@" ;;
  statusline)     cmd_statusline "$@" ;;
  version|-v|--version) echo "claude-profile $VERSION" ;;
  help|--help|-h)
    cat <<HELP
${BOLD}claude-profile${NC} v$VERSION — Switch between Claude Code configurations

${BOLD}USAGE${NC}
  claude-profile <command> [options]

${BOLD}COMMANDS${NC}
  new <name>                    Create a clean empty profile
  fork <name>                   Copy current state into a new profile
  use <name>                    Switch to a profile
  list                          List all profiles
  current                       Show active profile name
  show [name]                   Show profile contents
  edit [name]                   Open profile in editor
  delete <name> [-f]            Delete a profile
  deactivate                    Turn off profiles, restore original

${BOLD}HISTORY${NC}
  save [name] [-m message]      Save & commit current state
  history [name]                View change history (git log)
  diff [name] [commit|date]     Show changes (unsaved or since ref)
  restore [name] <commit|date>  Restore profile to a point in time

${BOLD}UI INTEGRATION${NC}
  prompt-init <shell>           Shell prompt integration (zsh/bash)
  statusline [install|uninstall] Claude Code status line

${BOLD}OTHER${NC}
  version                       Print version
  help                          Show this help

${BOLD}EXAMPLES${NC}
  claude-profile fork default          # Save current setup as "default"
  claude-profile new experiment        # Clean empty profile
  claude-profile fork review           # Fork current profile
  claude-profile use review            # Switch to profile

  eval "\$(claude-profile prompt-init zsh)"   # Profile in shell prompt
  claude-profile statusline install           # Profile in Claude Code

${BOLD}WHAT GETS SWITCHED${NC}
  settings.json  CLAUDE.md  agents/  skills/  rules/  keybindings.json
  ~/.claude.json (MCP servers)

${BOLD}FILES${NC}
  Profiles dir:  \$CLAUDE_CODE_HOME/profiles (default: ~/.claude/profiles)

HELP
    ;;
  *)
    err "Unknown command: $cmd"
    echo "Run 'claude-profile help' for usage"
    exit 1
    ;;
esac
